# Leave empty for local dev — Vite proxies /api to http://127.0.0.1:8092
VITE_API_BASE=

# Vercel production — same-origin rewrite (see root vercel.json /backend → Oracle)
# VITE_API_BASE=/backend

# Direct Oracle HTTP (local testing only; browsers may block mixed content on HTTPS sites)
# VITE_API_BASE=http://163.192.61.140:8092
