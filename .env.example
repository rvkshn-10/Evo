# ── Agency Identity ────────────────────────────────────────────────────────────
AGENCY_NAME="Emergency Management Office AI"

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── Neon Postgres (Vercel Storage integration) ────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Evo 1.0 ───────────────────────────────────────────────────────────────────
EVO_MODEL_VERSION=evo1.0
EVO_MODEL_REPO=https://github.com/rvkshn-10/Evo
EVO_PREFER_OPENVINO=true

# ── CORS (Vercel frontend URL) ───────────────────────────────────────────────
CORS_ORIGINS=https://your-app.vercel.app

# ── Web Research ──────────────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here

# ── PeopleSense (crowd occupancy) ─────────────────────────────────────────────
PEOPLESENSE_API_KEY=placeholder
PEOPLESENSE_BASE_URL=https://api.peoplesense.ai

# ── NOAA / NWS ────────────────────────────────────────────────────────────────
NWS_USER_AGENT=(emergency-management-office-ai, contact@example.com)
DEFAULT_ALERT_AREA=CA
DEFAULT_MAP_LAT=38.58
DEFAULT_MAP_LON=-121.30

# ── USGS Earthquake Early Warning ─────────────────────────────────────────────
USGS_EEW_MIN_MAGNITUDE=4.0

# ── PeopleSense auto-deployment ───────────────────────────────────────────────
PEOPLESENSE_AUTO_DEPLOY=true

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8092
DEBUG=True
LOG_LEVEL=INFO

# ── Output ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
