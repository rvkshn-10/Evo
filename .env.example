# ── Agency Identity ────────────────────────────────────────────────────────────
AGENCY_NAME="Emergency Management Office AI"

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── Disaster history (local SQLite default; optional Neon Postgres) ───────────
# Leave DATABASE_URL empty to use data/disaster_history.db on the API server.
# Set DATABASE_URL when API and DB run on different hosts (e.g. Neon).
DATABASE_URL=
# DISASTER_HISTORY_DB=./data/disaster_history.db

# ── Evo model ─────────────────────────────────────────────────────────────────
EVO_MODEL_VERSION=evo1.2
EVO_MODEL_REPO=https://github.com/rvkshn-10/Evo
EVO_PREFER_OPENVINO=true
EVO_HYBRID_MODE=true
# auto | cpu | ncs1 | ncs2 — Neural Compute Stick (USB) on local Mac; use auto until stick is plugged in
EVO_ACCELERATOR=auto
EVO_TIME_CATEGORIES=Train Station

# ── CORS (Vercel frontend URL) ───────────────────────────────────────────────
CORS_ORIGINS=https://evac-evo.vercel.app,http://localhost:5173

# ── Web Research ──────────────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here

# ── PeopleSense FCUSD (GET occupancy + POST events, x-api-key) ────────────────
# Rate limit: fetch occupancy at most once per PEOPLESENSE_CACHE_TTL_SECONDS (default 60s).
PEOPLESENSE_API_KEY=your-peoplesense-api-key
PEOPLESENSE_OCCUPANCY_URL=https://w8bdwhaps0.execute-api.us-west-2.amazonaws.com/v1/occupancy
PEOPLESENSE_CACHE_TTL_SECONDS=60
PEOPLESENSE_EVENT_URL=https://k0i6cg0ob2.execute-api.us-west-2.amazonaws.com/prod/event

# ── NOAA / NWS ────────────────────────────────────────────────────────────────
NWS_USER_AGENT=(emergency-management-office-ai, ravipothanngaari@gmail.com)
DEFAULT_ALERT_AREA=CA
DEFAULT_MAP_LAT=38.58
DEFAULT_MAP_LON=-121.30

# ── USGS Earthquake Early Warning ─────────────────────────────────────────────
USGS_EEW_MIN_MAGNITUDE=4.0

# ── NASA FIRMS wildfire hotspots (free key — optional) ────────────────────────
# Register: https://firms.modaps.eosdis.nasa.gov/api/
NASA_FIRMS_MAP_KEY=

# ── PeopleSense auto-deployment ───────────────────────────────────────────────
PEOPLESENSE_AUTO_DEPLOY=true

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8092
DEBUG=True
LOG_LEVEL=INFO

# ── Output ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
