{
  "model_version": "evo1.0",
  "input_name": "features",
  "input_dtype": "float32",
  "numeric_features": [
    "occupancy_log",
    "density",
    "severity_score",
    "hazard_magnitude"
  ],
  "categorical_features": {
    "category": [
      "Train Station",
      "Office Building",
      "Stadium"
    ],
    "scenario": [
      "Electrical Fire",
      "Tunnel Smoke",
      "Sudden Overcrowding",
      "Panic Chain Reaction",
      "Platform Fire",
      "Station Flooding",
      "Standard Evacuation Drill",
      "Blockage"
    ],
    "event_type": [
      "fire",
      "flood",
      "earthquake",
      "tornado",
      "tsunami",
      "other"
    ]
  },
  "feature_order": [
    "occupancy_log",
    "density",
    "severity_score",
    "hazard_magnitude",
    "category=Train Station",
    "category=Office Building",
    "category=Stadium",
    "scenario=Electrical Fire",
    "scenario=Tunnel Smoke",
    "scenario=Sudden Overcrowding",
    "scenario=Panic Chain Reaction",
    "scenario=Platform Fire",
    "scenario=Station Flooding",
    "scenario=Standard Evacuation Drill",
    "scenario=Blockage",
    "event_type=fire",
    "event_type=flood",
    "event_type=earthquake",
    "event_type=tornado",
    "event_type=tsunami",
    "event_type=other"
  ],
  "normalization": {
    "occupancy_log": {
      "transform": "log1p_then_standardize",
      "mean": 6.699229630261614,
      "scale": 0.8466795342433032
    },
    "density": {
      "transform": "clip_0_1",
      "missing_value": 0.55
    },
    "severity_score": {
      "transform": "clip_0_1",
      "default": 0.0
    },
    "hazard_magnitude": {
      "transform": "clip_min_0",
      "default": 0.0
    }
  },
  "scenario_by_event": {
    "fire": "Electrical Fire",
    "flood": "Station Flooding",
    "earthquake": "Panic Chain Reaction",
    "tsunami": "Station Flooding",
    "tornado": "Sudden Overcrowding",
    "other": "Standard Evacuation Drill"
  },
  "outputs": [
    "evacuation_success_pct",
    "evacuation_time_min"
  ],
  "derived_outputs": {
    "evacuation_rate": "clip(evacuation_success_pct / 100, 0, 1)",
    "risk_level": {
      "high": "evacuation_rate < 0.85 or density > 0.7",
      "medium": "evacuation_rate < 0.92",
      "low": "otherwise"
    }
  }
}
